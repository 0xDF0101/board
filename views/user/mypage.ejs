<%- include('../partials/header') %>

<div class="ig-auth-page">
  <div class="ig-auth-card" style="max-width: 480px;">

    <div style="display:flex; align-items:center; gap:24px; margin-bottom:28px;">
      <div style="display:flex; flex-direction:column; align-items:center; gap:8px;">
        <% if (user.profileImage) { %>
          <img src="<%= user.profileImage %>" class="ig-avatar" style="width:80px;height:80px;" alt="avatar">
        <% } else { %>
          <div class="ig-avatar-default" style="width:80px;height:80px;font-size:28px;"><%= user.userId.charAt(0).toUpperCase() %></div>
        <% } %>
        <form action="/users/mypage/profile-image" method="POST" enctype="multipart/form-data" style="display:flex; flex-direction:column; align-items:center; gap:4px;">
          <input type="file" name="profileImage" id="profileImageInput" accept="image/*" style="display:none;">
          <label for="profileImageInput" class="ig-auth-submit" style="width:auto; margin:0; padding:5px 12px; font-size:12px; cursor:pointer; white-space:nowrap;">파일 선택</label>
          <button type="submit" class="ig-auth-submit" style="width:auto; margin:0; padding:5px 12px; font-size:12px; white-space:nowrap;">변경</button>
        </form>
      </div>
      <div>
        <div style="font-size:20px; font-weight:700; color:#262626; margin-bottom:4px;">
          <%= user.nickname || user.userId %>
        </div>
        <div style="font-size:14px; color:#8e8e8e;">@<%= user.userId %></div>
      </div>
    </div>

    <hr style="border:none; border-top:1px solid #dbdbdb; margin-bottom:24px;">

    <div style="font-size:12px; font-weight:600; color:#8e8e8e; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:12px;">닉네임 변경</div>

    <form action="/users/mypage/nickname" method="POST" style="display:flex; gap:8px; align-items:center;">
      <input
        type="text"
        name="nickname"
        class="ig-auth-input"
        placeholder="새 닉네임 (2~10자)"
        value="<%= user.nickname || '' %>"
        maxlength="10"
        style="flex:1; margin:0;"
      >
      <button type="submit" class="ig-auth-submit" style="width:auto; margin:0; padding:9px 18px; white-space:nowrap;">변경</button>
    </form>

  </div>
</div>

<%- include('../partials/footer') %>
