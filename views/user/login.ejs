<%- include('../partials/header', {title:'로그인'}) %>

<div class="ig-auth-page">

  <div class="ig-auth-card">
    <div class="ig-auth-logo">
      <span class="ig-auth-logo-text">Board</span>
    </div>

    <form action="/users/login" method="POST">
      <div class="ig-auth-field">
        <input type="text" id="userId" name="userId" class="ig-auth-input" placeholder="아이디" required autocomplete="username" />
      </div>
      <div class="ig-auth-field">
        <input type="password" id="userPw" name="userPw" class="ig-auth-input" placeholder="비밀번호" required autocomplete="current-password" />
      </div>
      <button type="submit" class="ig-auth-submit">로그인</button>
    </form>

    <div class="ig-auth-divider">또는</div>

    <p style="text-align:center; font-size:14px;">
      <a href="/posts" style="color:#0095f6; font-weight:600;">게시판 바로가기</a>
    </p>
  </div>

  <div class="ig-auth-switch">
    계정이 없으신가요? <a href="/users/register">회원가입</a>
  </div>

</div>

<%- include('../partials/footer') %>
