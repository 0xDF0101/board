<%- include('../partials/header', {title:'게시글 목록'}) %>

<div class="ig-feed-wrap">

  <div id="ig-search-error" class="ig-search-error" style="display:none;"></div>

  <div class="ig-search-bar">
    <form action="/posts" method="GET" class="ig-search-form">
      <input type="text" name="q" value="<%= q %>" placeholder="검색..." class="ig-search-input" />
      <button type="submit" class="ig-btn ig-btn--ghost ig-btn--sm">검색</button>
      <% if (q) { %>
        <a href="/posts" class="ig-btn ig-btn--ghost ig-btn--sm">초기화</a>
      <% } %>
    </form>
  </div>

  <div id="post-container" data-q="<%= q %>">
    <% if (postsFromDB.length === 0 && q) { %>
      <p class="ig-empty">검색 결과가 없습니다.</p>
    <% } %>
    <% postsFromDB.forEach(function(post) { %>
      <article class="ig-card">

        <div class="ig-card-head">
          <% if (post.author && post.author.profileImage) { %>
            <img src="<%= post.author.profileImage %>" class="ig-avatar" alt="avatar">
          <% } else { %>
            <div class="ig-avatar-default">
              <%= post.author && post.author.userId ? post.author.userId.charAt(0).toUpperCase() : '?' %>
            </div>
          <% } %>
          <div class="ig-card-meta">
            <span class="ig-card-username">
              <% if (post.author && post.author.userId) { %>
                <a href="/users/<%= post.author.userId %>" class="ig-user-link">
                  <%= post.author.nickname || post.author.userId %>
                </a>
                <% if (post.author.role === 'admin') { %><span class="ig-admin-badge">관리자</span><% } %>
              <% } else { %>
                알 수 없음
              <% } %>
            </span>
            <span class="ig-card-time">
              <%= post.createdAt.toLocaleString('ko-KR', { timeZone: 'Asia/Seoul', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', hour12: false }) %>
            </span>
          </div>
          <% if (sessionUser && post.author && (String(post.author._id) === String(sessionUser._id) || sessionUser.role === 'admin')) { %>
            <div class="ig-card-menu">
              <button class="ig-more-btn" type="button">•••</button>
              <div class="ig-dropdown">
                <a href="/posts/<%= post._id %>/edit" class="ig-dropdown-item">수정</a>
                <form action="/posts/<%= post._id %>?_method=DELETE" method="POST" style="margin:0">
                  <button type="submit" class="ig-dropdown-item ig-dropdown-item--danger">삭제</button>
                </form>
              </div>
            </div>
          <% } %>
        </div>

        <% if (post.imageUrl) { %>
          <img src="<%= post.imageUrl %>" alt="post image" class="ig-card-img" style="object-fit:cover;">
        <% } else { %>
          <div class="ig-card-img"></div>
        <% } %>

        <div class="ig-card-actions">
          <button class="ig-like-btn likeBtn" data-id="<%= post._id %>">
            <svg viewBox="0 0 24 24">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            <span class="likeCount"><%= post.likes %></span>
          </button>
          <span class="ig-comment-count">
            <svg viewBox="0 0 24 24">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
            <%= post.commentCount %>
          </span>
        </div>

        <div class="ig-card-body">
          <span class="ig-card-title"><%= post.title %></span>
          <p class="ig-card-excerpt"><%= post.content.trim() %></p>
        </div>

        <div class="ig-card-comments">
          <% var visibleComments = post.comments.slice(0, 2); %>
          <% var hiddenComments = post.comments.slice(2); %>

          <% visibleComments.forEach(function(comment) { %>
            <div class="ig-comment-item">
              <div class="ig-comment-body">
                <% if (comment.author && comment.author.userId) { %>
                  <a href="/users/<%= comment.author.userId %>" class="ig-comment-author" style="text-decoration:none; color:inherit; cursor:pointer;">@<%= comment.author.userId %></a>
                <% } %>
                <span class="ig-comment-text"><%= comment.content %></span>
                <% if (sessionUser && comment.author && (String(comment.author._id) === String(sessionUser._id) || sessionUser.role === 'admin')) { %>
                  <form action="/comments/<%= post._id %>/comments/<%= comment._id %>?_method=PUT" method="POST" class="ig-comment-edit-form" style="display:none;">
                    <textarea name="content" class="ig-comment-input" rows="1"><%= comment.content %></textarea>
                    <button type="submit" class="ig-comment-submit">저장</button>
                    <button type="button" class="ig-comment-cancel">취소</button>
                  </form>
                <% } %>
              </div>
              <% if (sessionUser && comment.author && (String(comment.author._id) === String(sessionUser._id) || sessionUser.role === 'admin')) { %>
                <button type="button" class="ig-comment-edit">수정</button>
                <form action="/comments/<%= post._id %>/comments/<%= comment._id %>?_method=DELETE" method="POST" style="display:inline;">
                  <button type="submit" class="ig-comment-del">삭제</button>
                </form>
              <% } %>
            </div>
          <% }); %>

          <% if (hiddenComments.length > 0) { %>
            <button class="ig-show-more-btn"
                    data-target="hidden-<%= post._id %>"
                    data-label="댓글 <%= post.comments.length %>개 모두 보기">
              댓글 <%= post.comments.length %>개 모두 보기
            </button>
            <div class="ig-hidden-comments" id="hidden-<%= post._id %>">
              <% hiddenComments.forEach(function(comment) { %>
                <div class="ig-comment-item">
                  <div class="ig-comment-body">
                    <% if (comment.author && comment.author.userId) { %>
                      <span class="ig-comment-author">@<%= comment.author.userId %></span>
                    <% } %>
                    <span class="ig-comment-text"><%= comment.content %></span>
                    <% if (sessionUser && comment.author && (String(comment.author._id) === String(sessionUser._id) || sessionUser.role === 'admin')) { %>
                      <form action="/comments/<%= post._id %>/comments/<%= comment._id %>?_method=PUT" method="POST" class="ig-comment-edit-form" style="display:none;">
                        <textarea name="content" class="ig-comment-input" rows="1"><%= comment.content %></textarea>
                        <button type="submit" class="ig-comment-submit">저장</button>
                        <button type="button" class="ig-comment-cancel">취소</button>
                      </form>
                    <% } %>
                  </div>
                  <% if (sessionUser && comment.author && (String(comment.author._id) === String(sessionUser._id) || sessionUser.role === 'admin')) { %>
                    <button type="button" class="ig-comment-edit">수정</button>
                    <form action="/comments/<%= post._id %>/comments/<%= comment._id %>?_method=DELETE" method="POST" style="display:inline;">
                      <button type="submit" class="ig-comment-del">삭제</button>
                    </form>
                  <% } %>
                </div>
              <% }); %>
            </div>
          <% } %>

          <% if (sessionUser) { %>
            <form class="ig-comment-form" action="/comments/<%= post._id %>/comments" method="POST">
              <textarea name="content" class="ig-comment-input" rows="1" required placeholder="댓글 달기..."></textarea>
              <button type="submit" class="ig-comment-submit">게시</button>
            </form>
          <% } else { %>
            <p class="ig-login-hint"><a href="/users/login">로그인</a>하여 댓글을 달아보세요.</p>
          <% } %>
        </div>

      </article>
    <% }); %>
  </div>

  <div id="loading" class="ig-loading" style="display: none;">
    <div class="spinner-border spinner-border-sm text-secondary" role="status">
      <span class="visually-hidden">Loading...</span>
    </div>
  </div>

</div>

<script>
(function () {
  var params = new URLSearchParams(window.location.search);
  var err = params.get('searchError');
  if (err) {
    var el = document.getElementById('ig-search-error');
    el.textContent = err;
    el.style.display = 'block';
    history.replaceState(null, '', '/posts');
  }
})();
</script>
<script src="/js/like.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
  document.querySelectorAll('.ig-more-btn').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      var menu = btn.parentElement.querySelector('.ig-dropdown');
      var isOpen = menu.classList.contains('ig-dropdown--open');
      document.querySelectorAll('.ig-dropdown--open').forEach(function (d) {
        d.classList.remove('ig-dropdown--open');
      });
      if (!isOpen) menu.classList.add('ig-dropdown--open');
    });
  });

  document.addEventListener('click', function () {
    document.querySelectorAll('.ig-dropdown--open').forEach(function (d) {
      d.classList.remove('ig-dropdown--open');
    });
  });

  document.querySelectorAll('.ig-comment-edit').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var item = btn.closest('.ig-comment-item');
      item.querySelector('.ig-comment-text').style.display = 'none';
      item.querySelector('.ig-comment-edit-form').style.display = '';
      btn.style.display = 'none';
    });
  });

  document.querySelectorAll('.ig-comment-cancel').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var item = btn.closest('.ig-comment-item');
      item.querySelector('.ig-comment-text').style.display = '';
      item.querySelector('.ig-comment-edit-form').style.display = 'none';
      item.querySelector('.ig-comment-edit').style.display = '';
    });
  });

  document.querySelectorAll('.ig-show-more-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var target = document.getElementById(btn.dataset.target);
      if (!target) return;
      var isOpen = target.classList.contains('ig-hidden-comments--open');
      target.classList.toggle('ig-hidden-comments--open');
      btn.textContent = isOpen ? btn.dataset.label : '접기';
    });
  });
});
</script>
<script src="/js/infiniteScroll.js"></script>
<%- include('../partials/footer') %>
