<%- include('../partials/header', {title:'게시글 목록'}) %>

<div class="feed-topbar">
  <span class="feed-brand">Board</span>
  <div class="feed-topbar-right">
    <% if (sessionUser) { %>
      <span class="feed-user-badge">@<%= sessionUser.userId %></span>
      <a href="/posts/new" class="feed-btn feed-btn-dark">새 글 작성</a>
      <a href="/users/logout" class="feed-btn feed-btn-ghost">로그아웃</a>
    <% } else { %>
      <a href="/users/login" class="feed-btn feed-btn-dark">로그인</a>
      <a href="/users/register" class="feed-btn feed-btn-ghost">회원가입</a>
    <% } %>
  </div>
</div>

<div class="feed-grid" id="post-container">
  <% postsFromDB.forEach((post) => { %>
    <div class="feed-card">
      <a href="/posts/<%= post._id %>" class="feed-card-img-link">
        <div class="feed-card-img"></div>
      </a>
      <div class="feed-card-body">
        <div class="feed-card-meta">
          <span class="feed-author">
            <% if (post.author && post.author.userId) { %>
              @<%= post.author.userId %>
              <% if (post.author.role === 'admin') { %>
                <span class="feed-admin-badge">관리자</span>
              <% } %>
            <% } else { %>
              @알 수 없음
            <% } %>
          </span>
          <span class="feed-time">
            <%= post.createdAt.toLocaleString('ko-KR', { timeZone: 'Asia/Seoul', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', hour12: false }) %>
          </span>
        </div>
        <a href="/posts/<%= post._id %>" class="feed-card-title"><%= post.title %></a>
        <p class="feed-card-content truncate-lines"><%= post.content.trim() %></p>
        <div class="feed-card-actions">
          <button class="feed-like-btn likeBtn" data-id="<%= post._id %>" style="position:relative;z-index:2;">
            Like <span class="likeCount"><%= post.likes %></span>
          </button>
          <span class="feed-comment-count">댓글 <%= post.commentCount %></span>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<div id="loading" class="feed-loading" style="display: none;">
  <div class="spinner-border spinner-border-sm text-secondary" role="status">
    <span class="visually-hidden">Loading...</span>
  </div>
</div>

<script src="/js/infiniteScroll.js"></script>
<%- include('../partials/footer') %>
