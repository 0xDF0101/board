<%- include('../partials/header', {title: post.title}) %>

<div class="post-wrap">

  <div class="post-nav">
    <a href="/posts" class="feed-btn feed-btn-ghost">← 목록으로</a>
  </div>

  <!-- 게시글 카드 -->
  <div class="post-card">
    <div class="post-img-placeholder"></div>
    <div class="post-card-body">

      <div class="post-author-row">
        <div class="post-author-avatar"></div>
        <div class="post-author-info">
          <span class="post-author-name">
            <% if (post.author && post.author.userId) { %>
              @<%= post.author.userId %>
            <% } else { %>
              @알 수 없음
            <% } %>
          </span>
          <span class="post-time">
            <%= post.createdAt.toLocaleString('ko-KR', { timeZone: 'Asia/Seoul', year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', hour12: false }) %>
          </span>
        </div>
        <div class="post-owner-actions">
          <a href="/posts/<%= post._id %>/edit" class="feed-btn feed-btn-ghost">수정</a>
          <form action="/posts/<%= post._id %>?_method=DELETE" method="POST" style="display:inline;">
            <button class="feed-btn feed-btn-danger" type="submit">삭제</button>
          </form>
        </div>
      </div>

      <h2 class="post-title"><%= post.title %></h2>
      <p class="post-content preserve-lines"><%= post.content.trim() %></p>

      <div class="post-actions">
        <button class="feed-like-btn likeBtn" data-id="<%= post._id %>">
          Like <span class="likeCount"><%= post.likes %></span>
        </button>
      </div>

    </div>
  </div>

  <!-- 댓글 섹션 -->
  <div class="comments-section">
    <h3 class="comments-title">댓글 <%= comments.length %></h3>

    <% if (comments.length === 0) { %>
      <p class="comments-empty">아직 댓글이 없습니다.</p>
    <% } else { %>
      <div class="comments-list">
        <% comments.forEach((comment) => { %>
          <div class="comment-item">
            <div class="comment-body">
              <% if (comment.author && comment.author.userId) { %>
                <span class="comment-author">@<%= comment.author.userId %></span>
              <% } %>
              <span class="comment-content"><%= comment.content %></span>
              <span class="comment-time">
                <%= comment.createdAt.toLocaleString('ko-KR', { timeZone: 'Asia/Seoul', year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', hour12: false }) %>
              </span>
            </div>
            <% if (sessionUser && comment.author && (comment.author._id.equals(sessionUser._id) || sessionUser.role === 'admin')) { %>
              <form action="/comments/<%= post._id %>/comments/<%= comment._id %>?_method=DELETE" method="POST" style="display:inline;">
                <button type="submit" class="comment-delete-btn">삭제</button>
              </form>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>

    <!-- 댓글 작성 -->
    <% if (sessionUser) { %>
      <form class="comment-form" action="/comments/<%= post._id %>/comments" method="POST">
        <textarea name="content" class="comment-input" rows="2" required placeholder="댓글을 입력하세요"></textarea>
        <div style="text-align:right;">
          <button type="submit" class="feed-btn feed-btn-dark">작성</button>
        </div>
      </form>
    <% } else { %>
      <p class="comments-empty">
        <a href="/users/login" class="no-style-link" style="color:#3897f0;">로그인</a> 후 댓글을 작성할 수 있습니다.
      </p>
    <% } %>
  </div>

</div>

<%- include('../partials/footer') %>
