<%- include('../partials/header', {title: post.title}) %>

<div class="ig-post-wrap">

  <a href="/posts" class="ig-post-back">
    <svg viewBox="0 0 24 24">
      <line x1="19" y1="12" x2="5" y2="12"/>
      <polyline points="12 19 5 12 12 5"/>
    </svg>
    목록으로
  </a>

  <div class="ig-post-card">

    <div class="ig-post-card-head">
      <div class="ig-avatar-md"></div>
      <div class="ig-post-user">
        <span class="ig-post-username">
          <% if (post.author && post.author.userId) { %>
            @<%= post.author.userId %>
          <% } else { %>
            @알 수 없음
          <% } %>
        </span>
        <span class="ig-post-time">
          <%= post.createdAt.toLocaleString('ko-KR', { timeZone: 'Asia/Seoul', year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', hour12: false }) %>
        </span>
      </div>
      <% if (sessionUser && post.author && (post.author._id.equals(sessionUser._id) || sessionUser.role === 'admin')) { %>
        <div class="ig-post-owner-btns">
          <a href="/posts/<%= post._id %>/edit" class="ig-btn ig-btn--ghost ig-btn--sm">수정</a>
          <form action="/posts/<%= post._id %>?_method=DELETE" method="POST" style="display:inline;">
            <button class="ig-btn ig-btn--danger ig-btn--sm" type="submit">삭제</button>
          </form>
        </div>
      <% } %>
    </div>

    <div class="ig-post-img"></div>

    <div class="ig-post-card-body">
      <div class="ig-post-actions">
        <button class="ig-like-btn likeBtn" data-id="<%= post._id %>">
          <svg viewBox="0 0 24 24">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
          <span class="likeCount"><%= post.likes %></span>
        </button>
      </div>

      <h1 class="ig-post-title"><%= post.title %></h1>
      <div class="ig-post-content preserve-lines"><%= post.content.trim() %></div>
    </div>

  </div>

  <div class="ig-comments">
    <div class="ig-comments-head">댓글 <%= comments.length %></div>

    <% if (comments.length === 0) { %>
      <p class="ig-comment-empty">아직 댓글이 없습니다.</p>
    <% } else { %>
      <div class="ig-comments-list">
        <% comments.forEach((comment) => { %>
          <div class="ig-comment-item">
            <div class="ig-comment-body">
              <% if (comment.author && comment.author.userId) { %>
                <span class="ig-comment-author">@<%= comment.author.userId %></span>
              <% } %>
              <span class="ig-comment-text"><%= comment.content %></span>
              <span class="ig-comment-time">
                <%= comment.createdAt.toLocaleString('ko-KR', { timeZone: 'Asia/Seoul', year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', hour12: false }) %>
              </span>
            </div>
            <% if (sessionUser && comment.author && (comment.author._id.equals(sessionUser._id) || sessionUser.role === 'admin')) { %>
              <form action="/comments/<%= post._id %>/comments/<%= comment._id %>?_method=DELETE" method="POST" style="display:inline;">
                <button type="submit" class="ig-comment-del">삭제</button>
              </form>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>

    <% if (sessionUser) { %>
      <form class="ig-comment-form" action="/comments/<%= post._id %>/comments" method="POST">
        <textarea name="content" class="ig-comment-input" rows="2" required placeholder="댓글 달기..."></textarea>
        <button type="submit" class="ig-comment-submit">게시</button>
      </form>
    <% } else { %>
      <p class="ig-login-hint">
        <a href="/users/login">로그인</a>하여 댓글을 달아보세요.
      </p>
    <% } %>
  </div>

</div>

<script src="/js/like.js"></script>
<%- include('../partials/footer') %>
