<%- include('../partials/header', {title: post.title}) %>

<div class="ig-form-wrap">
  <div class="ig-form-card">
    <h1 class="ig-form-title">게시글 수정</h1>
    <form action="/posts/<%=post._id%>?_method=PUT" method="POST">
      <div class="ig-field">
        <label class="ig-field-label" for="title">제목</label>
        <input type="text" id="title" name="title" value="<%= post.title %>" class="ig-input" required>
      </div>
      <div class="ig-field">
        <label class="ig-field-label" for="content">내용</label>
        <textarea id="content" name="content" class="ig-textarea" required><%= post.content %></textarea>
      </div>
      <div class="ig-form-actions">
        <button type="submit" class="ig-btn ig-btn--primary">수정 완료</button>
        <a href="/posts/<%= post._id %>" class="ig-btn ig-btn--ghost">취소</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
